---
/**
 * Marketing nav — auth-aware CTAs (Supplement 14) + burger menu (Supplement 16).
 *
 * Above 1135px:
 *   Signed out: Blog | divider | Log in   |  Request access (CTA)
 *   Signed in:  Blog                       |  Open Conjure (CTA)
 *
 * At <=1135px: the inline links + CTA hide; a burger appears on the right.
 * The burger toggles a drawer containing the same auth-aware items stacked.
 *
 * Auth state is determined server-side by the parent page reading
 * Astro.locals.auth() and passing isSignedIn down. Page must be SSR
 * (not prerendered) for that to populate.
 */
interface Props {
  isSignedIn?: boolean;
}
const { isSignedIn = false } = Astro.props as Props;
const ctaHref  = isSignedIn ? 'https://app.onconjure.com' : '/waitlist';
const ctaLabel = isSignedIn ? 'Open Conjure'              : 'Request access';
---
<nav class="marketing-nav" id="marketingNav" aria-label="Primary">
  <div class="nav-inner">
    <a class="nav-logo" href="/" aria-label="Conjure home">
      <svg viewBox="0 -2.5 24 24" width="28" height="28" fill="none" aria-hidden="true">
        <path d="M 5.12 17.12 A 1.25 1.25 0 0 0 6.88 18.88 L 16.16 8.40 A 0.4 0.4 0 0 0 15.60 7.84 Z" fill="currentColor"/>
        <circle cx="18" cy="6" r="1.5" fill="currentColor"/>
        <path d="M 18 2.5 L 18 0.5 M 20.5 3.5 L 21.9 2.1 M 21.4 6 L 23.4 6" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
      </svg>
      <span class="nav-wordmark">Conjure</span>
    </a>

    <div class="nav-links">
      <a href="/blog">Blog</a>
      {!isSignedIn && (
        <Fragment>
          <span class="nav-divider" aria-hidden="true"></span>
          <a class="nav-link--login" href="https://app.onconjure.com/sign-in">Log in</a>
        </Fragment>
      )}
    </div>

    <a class="nav-cta" href={ctaHref}>{ctaLabel}</a>

    <button
      class="nav-burger"
      id="navBurger"
      type="button"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="navDrawer"
    >
      <svg class="nav-burger__icon nav-burger__icon--menu" viewBox="0 0 24 24" width="24" height="24" fill="none" aria-hidden="true">
        <path d="M 4 7 L 20 7 M 10 12 L 20 12 M 4 17 L 20 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <svg class="nav-burger__icon nav-burger__icon--close" viewBox="0 0 24 24" width="24" height="24" fill="none" aria-hidden="true">
        <path d="M 7 7 L 17 17 M 17 7 L 7 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <div class="nav-h-line" aria-hidden="true"></div>

  <div class="nav-drawer" id="navDrawer" hidden>
    <a class="nav-drawer__link" href="/blog">Blog</a>
    {!isSignedIn && (
      <a class="nav-drawer__link" href="https://app.onconjure.com/sign-in">Log in</a>
    )}
    <a class="nav-drawer__cta" href={ctaHref}>{ctaLabel}</a>
  </div>
</nav>
