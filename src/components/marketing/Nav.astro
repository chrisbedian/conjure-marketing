---
/**
 * Marketing nav — ported from LumeGrid (`src/components/Header.astro`).
 *
 *  - At rest (top of page): fully transparent. The layout-line column
 *    (and the always-on horizontal divider below) read straight through.
 *  - On hover or once scrolled: cream-glass fill, blur, soft shadow.
 *  - The `nav-h-line` is the always-visible bottom divider, full viewport
 *    width, intersecting the vertical layout lines as a grid (Stripe-style).
 *
 * Styles live in `src/styles/marketing.css` (global, not scoped) so Vite
 * HMR can never strand cid-attribute selectors mid-update.
 */
---
<nav class="marketing-nav" id="marketingNav" aria-label="Primary">
  <div class="nav-inner">
    <a class="nav-logo" href="/" aria-label="Conjure home">
      <svg viewBox="0 -2.5 24 24" width="28" height="28" fill="none" aria-hidden="true">
        <path d="M 5.12 17.12 A 1.25 1.25 0 0 0 6.88 18.88 L 16.16 8.40 A 0.4 0.4 0 0 0 15.60 7.84 Z" fill="currentColor"/>
        <circle cx="18" cy="6" r="1.5" fill="currentColor"/>
        <path d="M 18 2.5 L 18 0.5 M 20.5 3.5 L 21.9 2.1 M 21.4 6 L 23.4 6" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
      </svg>
      <span class="nav-wordmark">Conjure</span>
    </a>

    <div class="nav-links">
      <a class="nav-link" href="/blog">Blog</a>
    </div>

    <div class="nav-actions">
      <a class="nav-link" href="https://app.onconjure.com/sign-in">Log in</a>
      <a class="nav-cta" href="https://app.onconjure.com/sign-up">Sign up</a>
    </div>
  </div>

  <div class="nav-h-line" aria-hidden="true"></div>
</nav>
