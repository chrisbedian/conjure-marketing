---
/**
 * Marketing nav.
 *
 * Above 1135px: Blog | divider | Log in | Get Started (CTA)
 * At <=1135px:  burger button → drawer with the same items stacked.
 *
 * The marketing site is fully static — auth state lives on the primary
 * (app.onconjure.com). The CTA always sends visitors to /waitlist; signed-in
 * users land on the app via the "Log in" link or by clicking through to it.
 */
---
<nav class="marketing-nav" id="marketingNav" aria-label="Primary" transition:persist="marketing-nav">
  <div class="nav-inner">
    <a class="nav-logo" href="/" aria-label="Conjure home">
      <svg viewBox="0 -2.5 24 24" width="28" height="28" fill="none" aria-hidden="true">
        <path d="M 5.12 17.12 A 1.25 1.25 0 0 0 6.88 18.88 L 16.16 8.40 A 0.4 0.4 0 0 0 15.60 7.84 Z" fill="currentColor"/>
        <circle cx="18" cy="6" r="1.5" fill="currentColor"/>
        <path d="M 18 2.5 L 18 0.5 M 20.5 3.5 L 21.9 2.1 M 21.4 6 L 23.4 6" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
      </svg>
      <span class="nav-wordmark">Conjure</span>
    </a>

    <div class="nav-links">
      <a href="/blog">Blog</a>
      <span class="nav-divider" aria-hidden="true"></span>
      <a class="nav-link--login" href="https://app.onconjure.com/sign-in">Log in</a>
    </div>

    <a class="nav-cta" href="/waitlist">Get Started</a>

    <button
      class="nav-burger"
      id="navBurger"
      type="button"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="navDrawer"
    >
      <svg class="nav-burger__svg" viewBox="0 0 24 24" width="24" height="24" fill="none" aria-hidden="true">
        <line class="nav-burger__line nav-burger__line--top" x1="4"  y1="7"  x2="20" y2="7"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line class="nav-burger__line nav-burger__line--mid" x1="10" y1="12" x2="20" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line class="nav-burger__line nav-burger__line--bot" x1="4"  y1="17" x2="20" y2="17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <div class="nav-h-line" aria-hidden="true"></div>

  <div class="nav-drawer" id="navDrawer" hidden>
    <a class="nav-drawer__link" href="/blog">Blog</a>
    <a class="nav-drawer__link" href="https://app.onconjure.com/sign-in">Log in</a>
    <a class="nav-drawer__cta" href="/waitlist">Get Started</a>
  </div>
</nav>
