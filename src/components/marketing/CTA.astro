---
---
<section class="cta reveal">
  <div class="cta__inner m-container">
    <h2 class="cta__title">Ready to direct?</h2>
    <p class="cta__sub">Open Conjure and try a real edit. No prompt box required.</p>
    <a href="https://app.onconjure.com" class="m-btn m-btn--primary m-btn--lg">Open Conjure</a>
  </div>
</section>

<style>
  .cta {
    background: var(--ink);
    padding: 120px var(--gutter);
  }
  @media (max-width: 767px) {
    .cta { padding: 96px var(--gutter); }
  }

  .cta__inner {
    max-width: 720px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cta__title {
    font-size: var(--text-h2);
    font-weight: 700;
    color: #FAFAFA;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .cta__sub {
    margin-top: 24px;
    color: rgba(255, 255, 255, 0.72);
    font-size: var(--text-lead);
    font-weight: 400;
    line-height: 1.45;
  }
  .cta .m-btn {
    margin-top: 40px;
  }
</style>
