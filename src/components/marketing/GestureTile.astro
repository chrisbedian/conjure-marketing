---
interface Props {
  title: string;
  description: string;
  videoSlug: string;   /* e.g. "selection" — resolves to /videos/gesture-selection.{webm,mp4} */
  delayMs?: number;
}
const { title, description, videoSlug, delayMs = 0 } = Astro.props;
const posterSrc = `/videos/gesture-${videoSlug}-poster.jpg`;
const webmSrc   = `/videos/gesture-${videoSlug}.webm`;
const mp4Src    = `/videos/gesture-${videoSlug}.mp4`;
---
<article class="tile reveal" style={`transition-delay: ${delayMs}ms;`}>
  <div class="tile__media" aria-label={`${title} gesture demo`}>
    <img
      src={posterSrc}
      alt=""
      class="tile__poster"
      decoding="async"
      loading="lazy"
    />
    <video
      class="tile__video"
      data-lazy
      data-crossfade
      muted
      loop
      playsinline
      preload="none"
      poster={posterSrc}
    >
      <source data-src={webmSrc} type="video/webm" />
      <source data-src={mp4Src}  type="video/mp4" />
    </video>
  </div>
  <h3 class="tile__title">{title}</h3>
  <p class="tile__desc">{description}</p>
</article>

<style>
  .tile {
    display: flex;
    flex-direction: column;
  }

  .tile__media {
    position: relative;
    aspect-ratio: 4 / 3;
    background: var(--ink);
    border: 1px solid rgba(5, 5, 7, 0.08);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition:
      transform   var(--dur-mid) var(--ease-out),
      box-shadow  var(--dur-mid) var(--ease-out);
  }
  .tile:hover .tile__media {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }
  @media (prefers-reduced-motion: reduce) {
    .tile:hover .tile__media { transform: none; }
  }

  .tile__poster,
  .tile__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .tile__video {
    opacity: 0;
    transition: opacity 200ms var(--ease-in-out);
  }
  .tile__video.is-playing {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .tile__video { opacity: 1; transition: none; }
  }

  .tile__title {
    margin-top: 1.5rem;
    font-size: var(--text-h3);
    font-weight: 600;
    color: var(--ink);
  }
  .tile__desc {
    margin-top: 0.5rem;
    color: var(--ink-muted);
    font-size: var(--text-body);
    line-height: 1.55;
  }
</style>
