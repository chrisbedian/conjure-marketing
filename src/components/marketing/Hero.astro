---
/**
 * Hero — editorial, anthropic-inspired, two-column upper.
 *  - Left column (1.5fr): chip → headline → subhead → CTA row
 *  - Right column (1fr):  mini gesture loop (CSS+SVG, no asset required)
 *  - Below: full-width hero loop bracketed by hairlines (unchanged)
 *
 * Asset paths under /public/videos/ are wired but the founder's recordings
 * land later. Until then the loop frame shows --ink at the right ratio.
 */
---
<section class="hero">
  <div class="m-section-left hero__intro">
    <p class="section-label">00 / Direct</p>

    <div class="hero__top">
      <div class="hero__top-left">
        <div class="hero__chip" aria-hidden="true">
          <span class="hero__chip-dot"></span>
          <span class="hero__chip-label">NOW IN PRIVATE BETA</span>
        </div>

        <h1 class="hero__title">
          <span class="hero__title-line">Direct the AI.</span><br />
          <span class="hero__title-line">Don't describe it.</span>
        </h1>
        <p class="hero__subtitle">
          An AI design tool for design professionals. Built around your gestures, not your prompts.
        </p>
        <div class="hero__cta-row">
          <a href="https://app.onconjure.com" class="m-btn m-btn--primary m-btn--md cta__btn">
            Open Conjure
            <svg class="cta__btn-arrow" viewBox="0 0 14 14" aria-hidden="true">
              <path d="M3 11 L11 3 M5 3 L11 3 L11 9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            </svg>
          </a>
          <a href="/blog" class="m-btn m-btn--ghost m-btn--md">Read the blog</a>
        </div>
      </div>

      <div class="hero__top-right">
        <div class="hero__mini" aria-label="A miniature loop showing a reference image dragged onto a layer; the layer adopts the reference's appearance">
          <svg viewBox="0 0 360 280" class="hero__mini-svg" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <!-- Reference swatch gradient: warm orange → pink → magenta -->
              <linearGradient id="miniRef" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%"   stop-color="#F4A261"/>
                <stop offset="50%"  stop-color="#E76F89"/>
                <stop offset="100%" stop-color="#B5377A"/>
              </linearGradient>

              <clipPath id="miniTargetClip">
                <rect x="32" y="110" width="296" height="64" rx="4"/>
              </clipPath>
            </defs>

            <!-- canvas -->
            <rect x="0" y="0" width="360" height="280" rx="10" fill="#1A1A1F"/>

            <!-- toolbar hint + corner dot -->
            <rect x="14" y="14" width="80" height="6" rx="3" fill="rgba(255,255,255,0.10)"/>
            <circle cx="338" cy="17" r="3" fill="rgba(255,255,255,0.18)"/>

            <!-- top decorative layer -->
            <rect x="32" y="60" width="120" height="36" rx="4" fill="rgba(255,255,255,0.08)"/>

            <!-- target layer: starts empty (subtle gray), fills with the reference gradient -->
            <g clip-path="url(#miniTargetClip)">
              <rect x="32" y="110" width="296" height="64" rx="4" fill="rgba(255,255,255,0.08)"/>
              <rect class="hero__mini-fill" x="32" y="110" width="296" height="64" rx="4" fill="url(#miniRef)" opacity="0"/>
            </g>

            <!-- bottom decorative layer -->
            <rect x="32" y="188" width="176" height="36" rx="4" fill="rgba(255,255,255,0.08)"/>

            <!-- selection ring on target (appears once dropped) -->
            <rect class="hero__mini-selection" x="29" y="107" width="302" height="70" rx="5"
                  fill="none" stroke="#8B2D5C" stroke-width="1.5" opacity="0"/>

            <!-- AI pulse dot at right edge of target -->
            <circle class="hero__mini-ai" cx="340" cy="142" r="3.5" fill="#8B2D5C" opacity="0"/>

            <!-- reference swatch: a small chip that flies in, follows the cursor, then disappears -->
            <g class="hero__mini-swatch">
              <rect x="-22" y="-16" width="44" height="32" rx="3" fill="url(#miniRef)" stroke="rgba(255,255,255,0.25)" stroke-width="1"/>
            </g>

            <!-- cursor -->
            <g class="hero__mini-cursor">
              <path d="M0 0 L0 14 L3.5 10.5 L6.5 16 L8.5 15 L5.5 9.5 L10 9.5 Z"
                    fill="#FAFAFA" stroke="#1A1A1F" stroke-width="0.5"/>
            </g>
          </svg>
        </div>
      </div>
    </div>
  </div>

  <div class="m-section-left">
    <hr class="m-divider" />
  </div>

  <div class="m-section-left hero__media-wrap">
    <div class="hero__loop" aria-label="A short loop of Conjure being used to edit a design">
      <img
        src="/videos/hero-loop-poster.jpg"
        alt=""
        class="hero__loop-poster"
        decoding="async"
        fetchpriority="high"
      />
      <video
        class="hero__loop-video"
        data-crossfade
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster="/videos/hero-loop-poster.jpg"
      >
        <source src="/videos/hero-loop.webm" type="video/webm" />
        <source src="/videos/hero-loop.mp4"  type="video/mp4" />
      </video>
    </div>
  </div>

  <div class="m-section-left">
    <hr class="m-divider" />
    <p class="hero__loop-meta" aria-hidden="true">
      <span>RECORDED IN CONJURE</span>
      <span class="hero__loop-meta-sep">·</span>
      <span>NO EDITS</span>
      <span class="hero__loop-meta-sep">·</span>
      <span>6.2s LOOP</span>
    </p>
  </div>
</section>

<style>
  .hero {
    background: var(--cream);
    padding: 96px 0 80px;
    position: relative;
  }
  /* Mobile: keep the same 32px gap between nav (64px tall, fixed) and the
     section-label as desktop has — drop only the bottom padding. */
  @media (max-width: 767px) {
    .hero { padding: 96px 0 56px; }
  }

  .hero__intro .section-label {
    margin-bottom: 32px;
  }

  /* Two-column upper hero. Stacks at <900px. */
  .hero__top {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(0, 1fr);
    gap: 64px;
    align-items: center;
    margin-bottom: 56px;
  }
  @media (max-width: 899px) {
    .hero__top {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  /* Status chip — mono "NOW IN PRIVATE BETA" with a pulsing plum dot. */
  .hero__chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px 6px 10px;
    background: var(--plum-wash);
    border: 1px solid rgba(139, 45, 92, 0.18);
    border-radius: 999px;
    margin-bottom: 24px;
  }
  .hero__chip-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--plum);
    animation: chip-pulse 2400ms var(--ease-in-out) infinite;
  }
  .hero__chip-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--plum-deep);
  }
  @keyframes chip-pulse {
    0%, 100% { box-shadow: 0 0 0 0   rgba(139, 45, 92, 0.5); }
    60%      { box-shadow: 0 0 0 6px rgba(139, 45, 92, 0);   }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__chip-dot { animation: none; }
  }

  .hero__title {
    font-size: clamp(3rem, 6vw, 5.75rem);
    font-weight: 700;
    color: var(--ink);
    line-height: 1.02;
    letter-spacing: -0.025em;
    max-width: 16ch;
  }
  /* When the hero stacks single-column the headline gets the full layout
     column to itself, so scale it more aggressively. */
  @media (max-width: 899px) {
    .hero__title {
      font-size: clamp(3rem, 9vw, 5.75rem);
    }
  }
  /* Each clause stays as one line at any viewport that can hold it. The
     <br /> still creates the explicit break between the two lines; this
     just prevents the browser from breaking *within* a clause when the
     column is right at the boundary of the rendered text width. Allow
     normal wrapping under 600px where the column gets too narrow for
     the larger of the two clauses. */
  .hero__title-line {
    white-space: nowrap;
  }
  @media (max-width: 599px) {
    .hero__title-line { white-space: normal; }
  }

  .hero__subtitle {
    margin-top: 28px;
    color: var(--ink-soft);
    font-size: clamp(1.0625rem, 1.4vw, 1.375rem);
    font-weight: 400;
    line-height: 1.5;
    max-width: 540px;
  }

  .hero__cta-row {
    margin-top: 40px;
    display: inline-flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  /* Animated arrow inside the primary CTA. */
  .cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .cta__btn-arrow {
    width: 14px;
    height: 14px;
    transition: transform var(--dur-base) var(--ease-out);
  }
  .cta__btn:hover .cta__btn-arrow {
    transform: translate(2px, -2px);
  }
  @media (prefers-reduced-motion: reduce) {
    .cta__btn-arrow { transition: none; }
    .cta__btn:hover .cta__btn-arrow { transform: none; }
  }

  /* ------------------------------------------------------------------
     Mini gesture loop — CSS+SVG, 6s repeating cycle. No video asset.
     Story: cursor enters with a warm gradient swatch, drags it onto an
     empty target layer, drops it. Selection blooms, AI dot pulses, the
     target fills with the reference gradient. Hold. Reset. Loop.
     "Drop a reference, the AI matches it" — without text.
     ------------------------------------------------------------------ */
  .hero__mini {
    width: 100%;
    max-width: 420px;
    margin-left: auto;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: var(--shadow-md);
    border: 1px solid rgba(26, 26, 31, 0.10);
  }
  /* Below 900px the layout stacks single-column; let the mini fill the
     full column flush-left, matching the text above. */
  @media (max-width: 899px) {
    .hero__mini {
      margin-left: 0;
      max-width: none;
    }
  }
  .hero__mini-svg {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Cursor: enters from upper-right, drags to the target, holds, exits.
     Path: (300, 40) → (180, 142) → fade out → restart. */
  .hero__mini-cursor {
    animation: mini-cursor 6000ms var(--ease-in-out) infinite;
  }
  @keyframes mini-cursor {
    0%   { transform: translate(300px, 40px);  opacity: 0; }
    4%   { opacity: 1; }
    10%  { transform: translate(300px, 40px); }
    37%  { transform: translate(180px, 142px); }   /* arrives at target */
    73%  { transform: translate(180px, 142px); }   /* holds */
    90%  { transform: translate(180px, 142px); opacity: 1; }
    98%  { opacity: 0; }
    100% { transform: translate(300px, 40px);  opacity: 0; }
  }

  /* Swatch: appears with the cursor, follows it (offset 12,12), drops at ~50%. */
  .hero__mini-swatch {
    animation: mini-swatch 6000ms var(--ease-in-out) infinite;
  }
  @keyframes mini-swatch {
    0%, 4%   { transform: translate(312px, 52px);  opacity: 0; }
    8%       { transform: translate(312px, 52px);  opacity: 1; }
    37%      { transform: translate(192px, 154px); opacity: 1; }
    47%      { transform: translate(192px, 154px); opacity: 1; }
    53%      { transform: translate(192px, 154px); opacity: 0; }   /* dropped */
    100%     { transform: translate(312px, 52px);  opacity: 0; }
  }

  /* Selection ring: appears as cursor arrives, holds through the fill, fades. */
  .hero__mini-selection {
    animation: mini-selection 6000ms var(--ease-in-out) infinite;
  }
  @keyframes mini-selection {
    0%,  35%  { opacity: 0; }
    42%, 88%  { opacity: 1; }
    95%, 100% { opacity: 0; }
  }

  /* AI pulse: brief bloom right after drop. */
  .hero__mini-ai {
    transform-box: fill-box;
    transform-origin: center;
    animation: mini-ai 6000ms var(--ease-in-out) infinite;
  }
  @keyframes mini-ai {
    0%, 50%  { opacity: 0;   transform: scale(0.6); }
    55%      { opacity: 1;   transform: scale(1.1); }
    62%      { opacity: 0.9; transform: scale(1); }
    72%      { opacity: 0;   transform: scale(0.6); }
    100%     { opacity: 0;   transform: scale(0.6); }
  }

  /* Target fill: fades in as the AI executes, holds, fades out on reset. */
  .hero__mini-fill {
    animation: mini-fill 6000ms var(--ease-in-out) infinite;
  }
  @keyframes mini-fill {
    0%,  55%  { opacity: 0; }
    73%, 88%  { opacity: 1; }
    95%, 100% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__mini-cursor,
    .hero__mini-swatch,
    .hero__mini-selection,
    .hero__mini-ai,
    .hero__mini-fill { animation: none; }
    .hero__mini-selection,
    .hero__mini-fill { opacity: 1; }
    .hero__mini-swatch,
    .hero__mini-cursor,
    .hero__mini-ai { opacity: 0; }
  }

  /* Hairlines bracket the full-width hero loop, full layout-column width. */
  .m-divider { margin-block: 64px; }
  @media (max-width: 767px) {
    .m-divider { margin-block: 40px; }
  }

  .hero__loop {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    background: var(--ink);
    border: 1px solid rgba(26, 26, 31, 0.10);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }
  .hero__loop-poster,
  .hero__loop-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero__loop-video {
    opacity: 0;
    transition: opacity 200ms var(--ease-in-out);
  }
  .hero__loop-video.is-playing {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__loop-video { opacity: 1; transition: none; }
  }

  /* Mono caption, sits just under the lower hairline like a film slate. */
  .hero__loop-meta {
    margin-top: 24px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    color: var(--ink-quiet);
    display: inline-flex;
    gap: 10px;
    align-items: center;
    letter-spacing: 0.04em;
  }
  .hero__loop-meta-sep {
    opacity: 0.5;
  }
  .hero .m-divider + .hero__loop-meta {
    margin-top: 24px;
  }

  /* Page-load staggered fade-in (hero only, runs once). */
  @media (prefers-reduced-motion: no-preference) {
    .hero__intro .section-label { animation: hero-fade-in 600ms var(--ease-out)   0ms both; }
    .hero__chip                  { animation: hero-fade-in 600ms var(--ease-out)  80ms both; }
    .hero__title                 { animation: hero-fade-in 700ms var(--ease-out) 160ms both; }
    .hero__subtitle              { animation: hero-fade-in 700ms var(--ease-out) 280ms both; }
    .hero__cta-row               { animation: hero-fade-in 700ms var(--ease-out) 400ms both; }
    .hero__top-right             { animation: hero-fade-in 800ms var(--ease-out) 240ms both; }
    .hero__media-wrap            { animation: hero-fade-in 800ms var(--ease-out) 560ms both; }
    @keyframes hero-fade-in {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  }
</style>
