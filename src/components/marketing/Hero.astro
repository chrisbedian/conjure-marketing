---
/**
 * Hero — editorial, anthropic-inspired.
 * Left-anchored section label + massive headline + body + CTAs, then a
 * full-column hero loop bracketed by hairlines. No flourishes (no wash,
 * no LIVE pip) — typography and the loop carry the weight.
 *
 * Asset paths under /public/videos/ are wired but the founder's recordings
 * land later. Until then the loop frame shows --ink at the right ratio.
 */
---
<section class="hero">
  <div class="m-section-left hero__intro">
    <div class="m-section-left__inner">
      <p class="section-label">00 / Direct</p>
      <h1 class="hero__title">
        Direct the AI.<br />
        Don't describe it.
      </h1>
      <p class="hero__subtitle">
        An AI design tool for design professionals. Built around your gestures, not your prompts.
      </p>
      <div class="hero__cta-row">
        <a href="https://app.onconjure.com" class="m-btn m-btn--primary m-btn--md cta__btn">
          Open Conjure
          <svg class="cta__btn-arrow" viewBox="0 0 14 14" aria-hidden="true">
            <path d="M3 11 L11 3 M5 3 L11 3 L11 9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          </svg>
        </a>
        <a href="/blog" class="m-btn m-btn--ghost m-btn--md">Read the blog</a>
      </div>
    </div>
  </div>

  <div class="m-section-left">
    <hr class="m-divider" />
  </div>

  <div class="m-section-left hero__media-wrap">
    <div class="hero__loop" aria-label="A short loop of Conjure being used to edit a design">
      <img
        src="/videos/hero-loop-poster.jpg"
        alt=""
        class="hero__loop-poster"
        decoding="async"
        fetchpriority="high"
      />
      <video
        class="hero__loop-video"
        data-crossfade
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster="/videos/hero-loop-poster.jpg"
      >
        <source src="/videos/hero-loop.webm" type="video/webm" />
        <source src="/videos/hero-loop.mp4"  type="video/mp4" />
      </video>
    </div>
  </div>

  <div class="m-section-left">
    <hr class="m-divider" />
    <p class="hero__loop-meta" aria-hidden="true">
      <span>RECORDED IN CONJURE</span>
      <span class="hero__loop-meta-sep">·</span>
      <span>NO EDITS</span>
      <span class="hero__loop-meta-sep">·</span>
      <span>6.2s LOOP</span>
    </p>
  </div>
</section>

<style>
  .hero {
    background: var(--cream);
    padding: 96px 0 80px;
    position: relative;
  }
  @media (max-width: 767px) {
    .hero { padding: 64px 0 56px; }
  }

  .hero__intro .section-label {
    margin-bottom: 32px;
  }

  .hero__title {
    font-size: clamp(3rem, 7.5vw, 6.5rem);
    font-weight: 700;
    color: var(--ink);
    line-height: 1.02;
    letter-spacing: -0.03em;
    max-width: 16ch;
  }

  .hero__subtitle {
    margin-top: 28px;
    color: var(--ink-soft);
    font-size: clamp(1.0625rem, 1.4vw, 1.375rem);
    font-weight: 400;
    line-height: 1.5;
    max-width: 540px;
  }

  .hero__cta-row {
    margin-top: 40px;
    display: inline-flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  /* Animated arrow inside the primary CTA. */
  .cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .cta__btn-arrow {
    width: 14px;
    height: 14px;
    transition: transform var(--dur-base) var(--ease-out);
  }
  .cta__btn:hover .cta__btn-arrow {
    transform: translate(2px, -2px);
  }
  @media (prefers-reduced-motion: reduce) {
    .cta__btn-arrow { transition: none; }
    .cta__btn:hover .cta__btn-arrow { transform: none; }
  }

  /* Hairlines bracket the hero loop, full layout-column width. */
  .m-divider { margin-block: 64px; }
  @media (max-width: 767px) {
    .m-divider { margin-block: 40px; }
  }

  .hero__media-wrap {
    /* The loop container fills the layout column, with --ink edges that
       feather cleanly into the cream surface. */
  }

  .hero__loop {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    background: var(--ink);
    border: 1px solid rgba(26, 26, 31, 0.10);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }
  .hero__loop-poster,
  .hero__loop-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero__loop-video {
    opacity: 0;
    transition: opacity 200ms var(--ease-in-out);
  }
  .hero__loop-video.is-playing {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__loop-video { opacity: 1; transition: none; }
  }

  /* Mono caption, sits just under the lower hairline like a film slate. */
  .hero__loop-meta {
    margin-top: 24px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    color: var(--ink-quiet);
    display: inline-flex;
    gap: 10px;
    align-items: center;
    letter-spacing: 0.04em;
  }
  .hero__loop-meta-sep {
    opacity: 0.5;
  }
  .hero .m-divider + .hero__loop-meta {
    margin-top: 24px;
  }

  /* Page-load staggered fade-in (hero only, runs once). */
  @media (prefers-reduced-motion: no-preference) {
    .hero__intro .section-label { animation: hero-fade-in 600ms var(--ease-out)   0ms both; }
    .hero__title                 { animation: hero-fade-in 700ms var(--ease-out)  80ms both; }
    .hero__subtitle              { animation: hero-fade-in 700ms var(--ease-out) 200ms both; }
    .hero__cta-row               { animation: hero-fade-in 700ms var(--ease-out) 320ms both; }
    .hero__media-wrap            { animation: hero-fade-in 800ms var(--ease-out) 480ms both; }
    @keyframes hero-fade-in {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  }
</style>
