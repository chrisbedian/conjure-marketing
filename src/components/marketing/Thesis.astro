<section class="thesis reveal">
  <div class="thesis__inner m-container">
    <h2 class="thesis__title">
      The AI is the properties panel.<br />
      There's no prompt box.
    </h2>
    <p class="thesis__body">
      Conjure replaces typed prompts with the gestures designers already use — selecting a layer, dropping a pin, attaching a reference, locking what's done. The AI reads the room and executes precisely what you point at.
    </p>
  </div>
</section>

<style>
  .thesis {
    background: var(--cream-soft);
    padding: 160px var(--gutter);
  }
  @media (max-width: 767px) {
    .thesis { padding: 96px var(--gutter); }
  }

  .thesis__inner {
    max-width: 920px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .thesis__title {
    font-size: var(--text-h2);
    font-weight: 700;
    color: var(--ink);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .thesis__body {
    margin-top: 2rem;
    color: var(--ink-soft);
    font-size: var(--text-lead);
    font-weight: 400;
    line-height: 1.55;
    max-width: 640px;
  }
</style>
