<style>
  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    max-width: 1040px;
    margin: 0 auto;
  }
  .lockup {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--fg);
    text-decoration: none;
  }
  .wordmark {
    font-weight: 600;
    font-size: 16px;
    letter-spacing: -0.01em;
    line-height: 1;
  }
  .app-link {
    color: var(--muted);
    font-size: 0.9rem;
  }
  .app-link:hover {
    color: var(--fg);
  }
</style>
