---
/**
 * Hero — editorial, anthropic-inspired, two-column upper.
 *  - Left column (1.5fr): chip → headline → subhead → CTA row
 *  - Right column (1fr):  mini gesture loop (CSS+SVG, no asset required)
 *  - Below: full-width hero loop bracketed by hairlines (unchanged)
 *
 * Asset paths under /public/videos/ are wired but the founder's recordings
 * land later. Until then the loop frame shows --ink at the right ratio.
 */
---
<section class="hero">
  <div class="m-section-left hero__intro">
    <p class="section-label">00 / Direct</p>

    <div class="hero__top">
      <div class="hero__top-left">
        <div class="hero__chip" aria-hidden="true">
          <span class="hero__chip-dot"></span>
          <span class="hero__chip-label">NOW IN PRIVATE BETA</span>
        </div>

        <h1 class="hero__title">
          <span class="hero__title-line">Direct the AI.</span><br />
          <span class="hero__title-line">Don't describe it.</span>
        </h1>
        <p class="hero__subtitle">
          An AI design tool for design professionals. Built around your gestures, not your prompts.
        </p>
        <div class="hero__cta-row">
          <a href="https://app.onconjure.com" class="m-btn m-btn--primary m-btn--md cta__btn">
            Open Conjure
            <svg class="cta__btn-arrow" viewBox="0 0 14 14" aria-hidden="true">
              <path d="M3 11 L11 3 M5 3 L11 3 L11 9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            </svg>
          </a>
          <a href="/blog" class="m-btn m-btn--ghost m-btn--md">Read the blog</a>
        </div>
      </div>

      <div class="hero__top-right">
        <div class="hero__mini" aria-label="A miniature loop showing a reference photo dragged onto a card; the AI restyles the eyebrow, image, and button in a coordinated cascade">
          <svg viewBox="0 0 360 280" class="hero__mini-svg" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <!-- Reference photo: warm sunset gradient with a "horizon" -->
              <linearGradient id="miniRefSky" x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%"   stop-color="#F4A261"/>
                <stop offset="55%"  stop-color="#E76F89"/>
                <stop offset="100%" stop-color="#7E2A52"/>
              </linearGradient>
              <linearGradient id="miniRefHills" x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%"   stop-color="#5A1F3F"/>
                <stop offset="100%" stop-color="#2D0F1F"/>
              </linearGradient>

              <!-- Cascade fills (same gradients reused at element scale) -->
              <linearGradient id="miniBtnFill" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%"   stop-color="#F4A261"/>
                <stop offset="50%"  stop-color="#E76F89"/>
                <stop offset="100%" stop-color="#B5377A"/>
              </linearGradient>
              <linearGradient id="miniImgWash" x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%"   stop-color="#F4A261" stop-opacity="0.35"/>
                <stop offset="100%" stop-color="#7E2A52" stop-opacity="0.45"/>
              </linearGradient>

              <clipPath id="miniBtnClip">
                <rect x="32" y="186" width="116" height="34" rx="6"/>
              </clipPath>
              <clipPath id="miniImgClip">
                <rect x="32" y="52" width="296" height="78" rx="6"/>
              </clipPath>
              <clipPath id="miniRefClip">
                <rect x="-22" y="-16" width="44" height="32" rx="4"/>
              </clipPath>
            </defs>

            <!-- canvas -->
            <rect x="0" y="0" width="360" height="280" rx="10" fill="#1A1A1F"/>

            <!-- toolbar hint + corner dot -->
            <rect x="14" y="14" width="60" height="5" rx="2.5" fill="rgba(255,255,255,0.10)"/>
            <circle cx="338" cy="16.5" r="3" fill="rgba(255,255,255,0.18)"/>

            <!-- the website card -->
            <g class="hero__mini-card">
              <rect x="20" y="40" width="320" height="216" rx="10" fill="#23232B" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>

              <!-- image area: each shape has a base "before" version and a
                   tinted overlay that fades in during the cascade. -->
              <g clip-path="url(#miniImgClip)">
                <!-- sky -->
                <rect x="32" y="52" width="296" height="78" rx="6" fill="rgba(255,255,255,0.05)"/>
                <rect class="hero__mini-img-sky" x="32" y="52" width="296" height="78" rx="6" fill="url(#miniImgWash)" opacity="0"/>

                <!-- mountain silhouette -->
                <path d="M32 130 L100 92 L150 110 L210 78 L270 108 L328 96 L328 130 Z" fill="rgba(255,255,255,0.08)"/>
                <path class="hero__mini-img-hills" d="M32 130 L100 92 L150 110 L210 78 L270 108 L328 96 L328 130 Z" fill="url(#miniRefHills)" opacity="0"/>

                <!-- sun -->
                <circle cx="276" cy="74" r="6" fill="rgba(255,255,255,0.10)"/>
                <circle class="hero__mini-img-sun" cx="276" cy="74" r="6" fill="#FFE5C2" opacity="0"/>
              </g>

              <!-- eyebrow: starts plum-tinted, animates to warm orange -->
              <rect class="hero__mini-eyebrow" x="32" y="142" width="48" height="6" rx="2" fill="rgba(194,139,170,0.55)"/>

              <!-- headline (two bars, do not change) -->
              <rect x="32" y="156" width="180" height="9" rx="2.5" fill="rgba(255,255,255,0.85)"/>
              <rect x="32" y="170" width="120" height="9" rx="2.5" fill="rgba(255,255,255,0.85)"/>

              <!-- button: empty/gray initially, fills with gradient on AI execute -->
              <g clip-path="url(#miniBtnClip)">
                <rect x="32" y="186" width="116" height="34" rx="6" fill="rgba(255,255,255,0.12)"/>
                <rect class="hero__mini-fill" x="32" y="186" width="116" height="34" rx="6" fill="url(#miniBtnFill)" opacity="0"/>
              </g>
              <rect x="56" y="199" width="68" height="8" rx="2" fill="rgba(255,255,255,0.95)"/>

              <!-- secondary link -->
              <rect x="164" y="200" width="56" height="6" rx="2" fill="rgba(255,255,255,0.40)"/>
            </g>

            <!-- selection ring around the whole card -->
            <rect class="hero__mini-selection" x="17" y="37" width="326" height="222" rx="12"
                  fill="none" stroke="#8B2D5C" stroke-width="1.5" opacity="0"/>

            <!-- reference photo chip: sky + hills + sun -->
            <g class="hero__mini-swatch">
              <g clip-path="url(#miniRefClip)">
                <rect x="-22" y="-16" width="44" height="32" fill="url(#miniRefSky)"/>
                <path d="M-22 6 L-10 -2 L-2 4 L8 -4 L18 2 L22 0 L22 16 L-22 16 Z" fill="url(#miniRefHills)"/>
                <circle cx="10" cy="-6" r="2.5" fill="#FFE5C2" opacity="0.85"/>
              </g>
              <rect x="-22" y="-16" width="44" height="32" rx="4" fill="none" stroke="rgba(255,255,255,0.30)" stroke-width="1"/>
            </g>

            <!-- cursor -->
            <g class="hero__mini-cursor">
              <path d="M0 0 L0 13 L4 10 L6 14 L7.5 13.5 L5.5 9.5 L10 9.5 Z"
                    fill="#FAFAFA" stroke="#1A1A1F" stroke-width="0.5"/>
            </g>
          </svg>
        </div>
      </div>
    </div>
  </div>

  <div class="m-section-left">
    <hr class="m-divider" />
  </div>

  <div class="m-section-left hero__media-wrap">
    <div class="hero__loop" aria-label="A short loop of Conjure being used to edit a design">
      <img
        src="/videos/hero-loop-poster.jpg"
        alt=""
        class="hero__loop-poster"
        decoding="async"
        fetchpriority="high"
      />
      <video
        class="hero__loop-video"
        data-crossfade
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster="/videos/hero-loop-poster.jpg"
      >
        <source src="/videos/hero-loop.webm" type="video/webm" />
        <source src="/videos/hero-loop.mp4"  type="video/mp4" />
      </video>
    </div>
  </div>

  <div class="m-section-left">
    <hr class="m-divider" />
    <p class="hero__loop-meta" aria-hidden="true">
      <span>RECORDED IN CONJURE</span>
      <span class="hero__loop-meta-sep">·</span>
      <span>NO EDITS</span>
      <span class="hero__loop-meta-sep">·</span>
      <span>6.2s LOOP</span>
    </p>
  </div>
</section>

<style>
  .hero {
    background: var(--cream);
    padding: 96px 0 80px;
    position: relative;
  }
  /* Mobile: keep the same 32px gap between nav (64px tall, fixed) and the
     section-label as desktop has — drop only the bottom padding. */
  @media (max-width: 767px) {
    .hero { padding: 96px 0 56px; }
  }

  .hero__intro .section-label {
    margin-bottom: 32px;
  }

  /* Two-column upper hero. Stacks at <900px. */
  .hero__top {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(0, 1fr);
    gap: 64px;
    align-items: center;
    margin-bottom: 56px;
  }
  @media (max-width: 899px) {
    .hero__top {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  /* Status chip — mono "NOW IN PRIVATE BETA" with a pulsing plum dot. */
  .hero__chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px 6px 10px;
    background: var(--plum-wash);
    border: 1px solid rgba(139, 45, 92, 0.18);
    border-radius: 999px;
    margin-bottom: 24px;
  }
  .hero__chip-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--plum);
    animation: chip-pulse 2400ms var(--ease-in-out) infinite;
  }
  .hero__chip-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--plum-deep);
  }
  @keyframes chip-pulse {
    0%, 100% { box-shadow: 0 0 0 0   rgba(139, 45, 92, 0.5); }
    60%      { box-shadow: 0 0 0 6px rgba(139, 45, 92, 0);   }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__chip-dot { animation: none; }
  }

  .hero__title {
    font-size: clamp(3rem, 6vw, 5.75rem);
    font-weight: 700;
    color: var(--ink);
    line-height: 1.02;
    letter-spacing: -0.025em;
    max-width: 16ch;
  }
  /* When the hero stacks single-column the headline gets the full layout
     column to itself, so scale it more aggressively. */
  @media (max-width: 899px) {
    .hero__title {
      font-size: clamp(3rem, 9vw, 5.75rem);
    }
  }
  /* Each clause stays as one line at any viewport that can hold it. The
     <br /> still creates the explicit break between the two lines; this
     just prevents the browser from breaking *within* a clause when the
     column is right at the boundary of the rendered text width. Allow
     normal wrapping under 600px where the column gets too narrow for
     the larger of the two clauses. */
  .hero__title-line {
    white-space: nowrap;
  }
  @media (max-width: 599px) {
    .hero__title-line { white-space: normal; }
  }

  .hero__subtitle {
    margin-top: 28px;
    color: var(--ink-soft);
    font-size: clamp(1.0625rem, 1.4vw, 1.375rem);
    font-weight: 400;
    line-height: 1.5;
    max-width: 540px;
  }

  .hero__cta-row {
    margin-top: 40px;
    display: inline-flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  /* Animated arrow inside the primary CTA. */
  .cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .cta__btn-arrow {
    width: 14px;
    height: 14px;
    transition: transform var(--dur-base) var(--ease-out);
  }
  .cta__btn:hover .cta__btn-arrow {
    transform: translate(2px, -2px);
  }
  @media (prefers-reduced-motion: reduce) {
    .cta__btn-arrow { transition: none; }
    .cta__btn:hover .cta__btn-arrow { transform: none; }
  }

  /* ------------------------------------------------------------------
     Mini gesture loop — CSS+SVG, 6s repeating cycle. No video asset.
     Story: cursor enters with a warm gradient swatch, drags it onto an
     empty target layer, drops it. Selection blooms, AI dot pulses, the
     target fills with the reference gradient. Hold. Reset. Loop.
     "Drop a reference, the AI matches it" — without text.
     ------------------------------------------------------------------ */
  .hero__mini {
    width: 100%;
    max-width: 420px;
    margin-left: auto;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: var(--shadow-md);
    border: 1px solid rgba(26, 26, 31, 0.10);
  }
  /* Below 900px the layout stacks single-column; let the mini fill the
     full column flush-left, matching the text above. */
  @media (max-width: 899px) {
    .hero__mini {
      margin-left: 0;
      max-width: none;
    }
  }
  .hero__mini-svg {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Cursor: enters from upper-right, drags reference toward card center,
     holds while the cascade runs, exits. */
  .hero__mini-cursor {
    animation: mini-cursor 7000ms var(--ease-in-out) infinite;
  }
  @keyframes mini-cursor {
    /* Tip is offset (-5, -7) from swatch center so the cursor body sits
       over the middle of the dragged image rather than dangling off it. */
    0%   { transform: translate(317px, 33px);  opacity: 0; }
    4%   { opacity: 1; }
    6%   { transform: translate(317px, 33px); }
    34%  { transform: translate(177px, 143px); }   /* arrives at card center */
    46%  { transform: translate(177px, 143px); opacity: 1; }   /* hold past the drop (40-44%) */
    54%  { transform: translate(177px, 143px); opacity: 0; }   /* then fade — no return trip */
    100% { transform: translate(177px, 143px); opacity: 0; }
  }

  /* Reference chip: follows cursor with a slight offset; fades on drop. */
  .hero__mini-swatch {
    animation: mini-swatch 7000ms var(--ease-in-out) infinite;
  }
  @keyframes mini-swatch {
    0%, 4%   { transform: translate(322px, 40px);  opacity: 0; }
    8%       { transform: translate(322px, 40px);  opacity: 1; }
    34%      { transform: translate(182px, 150px); opacity: 1; }
    40%      { transform: translate(182px, 150px); opacity: 1; }
    44%      { transform: translate(182px, 150px); opacity: 0; }   /* dropped */
    100%     { transform: translate(322px, 40px);  opacity: 0; }
  }

  /* Selection ring around the whole card: blooms on arrival, holds through
     the cascade, fades at the end. */
  .hero__mini-selection {
    animation: mini-selection 7000ms var(--ease-in-out) infinite;
  }
  @keyframes mini-selection {
    0%,  32%  { opacity: 0; }
    40%, 88%  { opacity: 1; }
    94%, 100% { opacity: 0; }
  }

  /* Cascade beat 1 — button fills with the sunset gradient (~50%). */
  .hero__mini-fill {
    animation: mini-cascade-btn 7000ms var(--ease-in-out) infinite;
  }
  @keyframes mini-cascade-btn {
    0%,  50%  { opacity: 0; }
    56%, 88%  { opacity: 1; }
    94%, 100% { opacity: 0; }
  }

  /* Cascade beat 2 — eyebrow tag shifts from plum to warm orange (~56%). */
  .hero__mini-eyebrow {
    animation: mini-cascade-eyebrow 7000ms var(--ease-in-out) infinite;
  }
  @keyframes mini-cascade-eyebrow {
    0%,  56%  { fill: rgba(194, 139, 170, 0.55); }
    62%, 88%  { fill: rgba(244, 162,  97, 0.95); }
    94%, 100% { fill: rgba(194, 139, 170, 0.55); }
  }

  /* Cascade beat 3 — image elements rise together: warm sky tint, plum
     hills overlay, cream sun. Sharing one timing window so they read as
     a single beat (rather than three sub-beats). */
  .hero__mini-img-sky,
  .hero__mini-img-hills,
  .hero__mini-img-sun {
    animation: mini-cascade-img 7000ms var(--ease-in-out) infinite;
  }
  @keyframes mini-cascade-img {
    0%,  62%  { opacity: 0; }
    68%, 88%  { opacity: 1; }
    94%, 100% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__mini-cursor,
    .hero__mini-swatch,
    .hero__mini-selection,
    .hero__mini-fill,
    .hero__mini-eyebrow,
    .hero__mini-img-sky,
    .hero__mini-img-hills,
    .hero__mini-img-sun { animation: none; }
    .hero__mini-selection,
    .hero__mini-fill,
    .hero__mini-img-sky,
    .hero__mini-img-hills,
    .hero__mini-img-sun { opacity: 1; }
    .hero__mini-eyebrow { fill: rgba(244, 162, 97, 0.95); }
    .hero__mini-swatch,
    .hero__mini-cursor { opacity: 0; }
  }

  /* Hairlines bracket the full-width hero loop, full layout-column width. */
  .m-divider { margin-block: 64px; }
  @media (max-width: 767px) {
    .m-divider { margin-block: 40px; }
  }

  .hero__loop {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    background: var(--ink);
    border: 1px solid rgba(26, 26, 31, 0.10);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }
  .hero__loop-poster,
  .hero__loop-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero__loop-video {
    opacity: 0;
    transition: opacity 200ms var(--ease-in-out);
  }
  .hero__loop-video.is-playing {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__loop-video { opacity: 1; transition: none; }
  }

  /* Mono caption, sits just under the lower hairline like a film slate. */
  .hero__loop-meta {
    margin-top: 24px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    color: var(--ink-quiet);
    display: inline-flex;
    gap: 10px;
    align-items: center;
    letter-spacing: 0.04em;
  }
  .hero__loop-meta-sep {
    opacity: 0.5;
  }
  .hero .m-divider + .hero__loop-meta {
    margin-top: 24px;
  }

  /* Page-load staggered fade-in (hero only, runs once). */
  @media (prefers-reduced-motion: no-preference) {
    .hero__intro .section-label { animation: hero-fade-in 600ms var(--ease-out)   0ms both; }
    .hero__chip                  { animation: hero-fade-in 600ms var(--ease-out)  80ms both; }
    .hero__title                 { animation: hero-fade-in 700ms var(--ease-out) 160ms both; }
    .hero__subtitle              { animation: hero-fade-in 700ms var(--ease-out) 280ms both; }
    .hero__cta-row               { animation: hero-fade-in 700ms var(--ease-out) 400ms both; }
    .hero__top-right             { animation: hero-fade-in 800ms var(--ease-out) 240ms both; }
    .hero__media-wrap            { animation: hero-fade-in 800ms var(--ease-out) 560ms both; }
    @keyframes hero-fade-in {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  }
</style>
