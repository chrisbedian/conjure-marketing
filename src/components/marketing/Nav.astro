---
/**
 * Marketing nav — auth-aware CTAs (Supplement 14):
 *   Signed out: Blog | Log in (text, hidden on mobile) | Request access
 *   Signed in:  Blog | Open Conjure
 *
 * The auth state is determined server-side by the parent page reading
 * Astro.locals.auth() and passing isSignedIn down. Page must be SSR
 * (not prerendered) for that to populate.
 */
interface Props {
  isSignedIn?: boolean;
}
const { isSignedIn = false } = Astro.props;
---
<nav class="marketing-nav" id="marketingNav" aria-label="Primary">
  <div class="nav-inner">
    <a class="nav-logo" href="/" aria-label="Conjure home">
      <svg viewBox="0 -2.5 24 24" width="28" height="28" fill="none" aria-hidden="true">
        <path d="M 5.12 17.12 A 1.25 1.25 0 0 0 6.88 18.88 L 16.16 8.40 A 0.4 0.4 0 0 0 15.60 7.84 Z" fill="currentColor"/>
        <circle cx="18" cy="6" r="1.5" fill="currentColor"/>
        <path d="M 18 2.5 L 18 0.5 M 20.5 3.5 L 21.9 2.1 M 21.4 6 L 23.4 6" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
      </svg>
      <span class="nav-wordmark">Conjure</span>
    </a>

    <div class="nav-links">
      <a href="/blog">Blog</a>
      {!isSignedIn && (
        <a class="nav-link--login" href="https://app.onconjure.com/sign-in">Log in</a>
      )}
    </div>

    {isSignedIn ? (
      <a class="nav-cta" href="https://app.onconjure.com">Open Conjure</a>
    ) : (
      <a class="nav-cta" href="/waitlist">Request access</a>
    )}
  </div>

  <div class="nav-h-line" aria-hidden="true"></div>
</nav>
