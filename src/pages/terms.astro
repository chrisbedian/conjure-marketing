---
import '../styles/marketing.css';
import { ClientRouter } from 'astro:transitions';
import LayoutLines from '../components/marketing/LayoutLines.astro';
import Nav from '../components/marketing/Nav.astro';
import Footer from '../components/marketing/Footer.astro';

export const prerender = true;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>Terms — Conjure</title>
    <meta name="description" content="Conjure terms of service." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=JetBrains+Mono:wght@400;500&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
    />
    <ClientRouter />
  </head>
  <body>
    <LayoutLines />
    <Nav />
    <main class="legal m-container">
      <h1>Terms</h1>
      <p>Our terms of service are forthcoming. Reach out to <a href="mailto:hello@onconjure.com">hello@onconjure.com</a> for questions in the meantime.</p>
    </main>
    <Footer />

    <script>
      import '../scripts/nav-scroll';
    </script>

    <style>
      .legal {
        padding: 112px var(--gutter) 160px;
        max-width: 720px;
      }
      .legal h1 {
        font-family: var(--font-display);
        font-size: clamp(2.5rem, 3.5vw, 3rem);
        font-weight: 500;
        color: var(--ink);
        line-height: 1.05;
        letter-spacing: -0.012em;
        margin-bottom: 1.5rem;
      }
      .legal p {
        color: var(--ink-soft);
        font-size: var(--text-body);
        line-height: 1.6;
      }
      .legal a {
        color: var(--prussian);
        text-decoration: underline;
        text-underline-offset: 3px;
      }
    </style>
  </body>
</html>
