---
/**
 * Marketing nav — floating cream-glass capsule that tightens to a flush band
 * on scroll. Ported from Lume Grid, adapted to Conjure's cream surface.
 *
 *  - Default (top of page): floating capsule, 8px from top, 8px radius,
 *    backdrop-blur(12px), no border, no shadow.
 *  - Scrolled (>32px): top:0, radius:0, 1px bottom border, soft shadow,
 *    blur tightens to 16px.
 *
 * The floating model means content flows under the nav — backdrop-blur
 * reveals the cream surface blurred behind the capsule.
 *
 * Styles live in `src/styles/marketing.css` (global, not scoped) so that
 * Vite HMR can never strand the cid-attribute selectors mid-update.
 */
---
<nav class="marketing-nav" id="marketingNav" aria-label="Primary">
  <div class="nav-inner">
    <a class="nav-logo" href="/" aria-label="Conjure home">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
        <path d="M6 18 L18 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <circle cx="18" cy="6" r="1.5" fill="currentColor"/>
        <path d="M18 2.5 L18 0.5 M21 3 L22.5 1.5 M22 6 L24 6" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
      </svg>
      <span class="nav-wordmark">Conjure</span>
    </a>

    <div class="nav-links">
      <a href="/blog">Blog</a>
    </div>

    <a class="nav-cta" href="https://app.onconjure.com">Open app</a>
  </div>
</nav>
