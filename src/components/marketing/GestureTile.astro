---
interface Props {
  title: string;
  description: string;
  numeral: string;     /* "01" | "02" | "03" | "04" */
  delayMs?: number;
}
const { title, description, numeral, delayMs = 0 } = Astro.props;
---
<article class="tile reveal" style={`transition-delay: ${delayMs}ms;`}>
  <hr class="tile__rule" />
  <header class="tile__head">
    <span class="tile__numeral" aria-hidden="true">{numeral}</span>
    <h3 class="tile__title">{title}</h3>
  </header>
  <p class="tile__desc">{description}</p>
</article>

<style>
  .tile {
    display: flex;
    flex-direction: column;
  }

  /* Anthropic-style hairline at the top of each card. */
  .tile__rule {
    border: none;
    border-top: 1px solid rgba(26, 26, 31, 0.10);
    margin: 0 0 20px;
    width: 100%;
  }

  .tile__head {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 20px;
  }
  .tile__numeral {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: 0.04em;
  }
  .tile__title {
    font-family: var(--font-sans);
    font-size: clamp(1.25rem, 1.75vw, 1.5rem);
    font-weight: 600;
    color: var(--ink);
    letter-spacing: -0.01em;
    line-height: 1.1;
  }

  .tile__desc {
    color: var(--ink-soft);
    font-size: var(--text-body);
    line-height: 1.55;
    max-width: 36ch;
  }
</style>
