---
import GestureTile from './GestureTile.astro';

const tiles = [
  {
    title: 'Selection.',
    description: "Click to point. The AI works on what you've chosen, nothing else.",
    videoSlug: 'selection',
  },
  {
    title: 'Reference.',
    description: 'Drop in an image. The AI matches the look without you describing it.',
    videoSlug: 'reference',
  },
  {
    title: 'Pins.',
    description: 'Mark a spot. The AI focuses there — no other layer is at risk.',
    videoSlug: 'pins',
  },
  {
    title: 'Locks.',
    description: "Lock what's done. The AI won't touch it, no matter what you ask for next.",
    videoSlug: 'locks',
  },
];
---
<section class="gestures">
  <div class="m-container">
    <header class="gestures__header reveal">
      <p class="gestures__eyebrow">THE GESTURE VOCABULARY</p>
      <h2 class="gestures__title">Direction at the speed of design.</h2>
      <p class="gestures__lead">
        Every channel is a way to tell the AI what you mean — without a prompt box, without copy-pasting, without explaining yourself.
      </p>
    </header>

    <div class="gestures__grid">
      {tiles.map((tile, i) => (
        <GestureTile
          title={tile.title}
          description={tile.description}
          videoSlug={tile.videoSlug}
          delayMs={i * 120}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .gestures {
    background: var(--cream);
    padding: 120px 0;
  }
  @media (max-width: 767px) {
    .gestures { padding: 80px 0; }
  }

  .gestures__header {
    max-width: 720px;
    margin: 0 auto 64px;
    text-align: center;
    padding-inline: var(--gutter);
  }
  .gestures__eyebrow {
    color: var(--indigo);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0;
  }
  .gestures__title {
    margin-top: 16px;
    font-size: var(--text-h2);
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .gestures__lead {
    margin: 24px auto 0;
    max-width: 560px;
    color: var(--ink-soft);
    font-size: var(--text-body);
    line-height: 1.55;
  }

  .gestures__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 32px;
    padding-inline: var(--gutter);
    max-width: var(--max-content);
    margin: 0 auto;
  }
  @media (max-width: 767px) {
    .gestures__grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }
</style>
