---
---
<section class="thesis reveal">
  <span class="section-marker" aria-hidden="true">01 / THESIS</span>

  <div class="m-section-left">
    <div class="m-section-left__inner">
      <h2 class="thesis__title">
        The AI is the properties panel.<br />
        There's no <span class="thesis__strike">prompt box</span>.
      </h2>
      <p class="thesis__body">
        Conjure replaces typed prompts with the gestures designers already use — selecting a layer, dropping a pin, attaching a reference, locking what's done. The AI reads the room and executes precisely what you point at.
      </p>
    </div>
  </div>
</section>

<style>
  .thesis {
    background: var(--cream-soft);
    padding: 160px 0;
    position: relative;
  }
  @media (max-width: 767px) {
    .thesis { padding: 96px 0; }
  }

  .thesis__title {
    font-size: var(--text-h2);
    font-weight: 700;
    color: var(--ink);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  /* Plum strikethrough draws across "prompt box" when the section reveals. */
  .thesis__strike {
    position: relative;
    display: inline-block;
  }
  .thesis__strike::after {
    content: '';
    position: absolute;
    left: -4px;
    right: -4px;
    top: 52%;
    height: 4px;
    background: var(--plum);
    transform: scaleX(0);
    transform-origin: left center;
    border-radius: 2px;
  }
  .thesis.is-visible .thesis__strike::after {
    animation: strike-draw 600ms var(--ease-out) 320ms forwards;
  }
  @keyframes strike-draw {
    to { transform: scaleX(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .thesis__strike::after {
      transform: scaleX(1);
      animation: none;
    }
  }

  .thesis__body {
    margin-top: 2rem;
    color: var(--ink-soft);
    font-size: var(--text-lead);
    font-weight: 400;
    line-height: 1.55;
  }
</style>
