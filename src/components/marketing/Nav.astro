---
/**
 * Marketing nav — floating cream-glass capsule that tightens to a flush band
 * on scroll. Ported from Lume Grid, adapted to Conjure's cream surface.
 *
 *  - Default (top of page): floating capsule, 8px from top, 8px radius,
 *    backdrop-blur(12px), no border, no shadow.
 *  - Scrolled (>32px): top:0, radius:0, 1px bottom border, soft shadow,
 *    blur tightens to 16px.
 *
 * The floating model means content flows under the nav — backdrop-blur
 * reveals the cream surface blurred behind the capsule.
 */
---
<nav class="marketing-nav" id="marketingNav" aria-label="Primary">
  <div class="nav-inner">
    <a class="nav-logo" href="/" aria-label="Conjure home">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
        <path d="M6 18 L18 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <circle cx="18" cy="6" r="1.5" fill="currentColor"/>
        <path d="M18 2.5 L18 0.5 M21 3 L22.5 1.5 M22 6 L24 6" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
      </svg>
      <span class="nav-wordmark">Conjure</span>
    </a>

    <div class="nav-links">
      <a href="/blog">Blog</a>
    </div>

    <a class="nav-cta" href="https://app.onconjure.com">Open app</a>
  </div>
</nav>

<style>
  .marketing-nav {
    position: fixed;
    left: 50%;
    transform: translateX(-50%);
    top: 8px;
    width: calc(100% - 36px);
    max-width: 1272px;
    height: 64px;
    z-index: 100;
    border-radius: 8px;
    background: rgba(236, 233, 224, 0.72);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid transparent;
    box-shadow: none;
    transition:
      top                 var(--dur-mid) var(--ease-in-out),
      border-radius       var(--dur-mid) var(--ease-in-out),
      border-bottom-color var(--dur-mid) var(--ease-in-out),
      backdrop-filter     var(--dur-mid) var(--ease-in-out),
      -webkit-backdrop-filter var(--dur-mid) var(--ease-in-out),
      box-shadow          var(--dur-mid) var(--ease-in-out);
  }

  .marketing-nav.is-scrolled {
    top: 0;
    border-radius: 0;
    border-bottom-color: rgba(5, 5, 7, 0.08);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: 0 2px 12px rgba(5, 5, 7, 0.04);
  }

  .nav-inner {
    height: 100%;
    padding: 0 20px;
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--ink);
    text-decoration: none;
    transition: color var(--dur-base) var(--ease-in-out);
  }
  .nav-logo:hover { color: var(--plum-deep); }

  .nav-wordmark {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .nav-links {
    flex: 1;
    display: flex;
    justify-content: flex-end;
    gap: 24px;
  }
  .nav-links a {
    font-size: 14px;
    font-weight: 500;
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 150ms var(--ease-in-out);
  }
  .nav-links a:hover { color: var(--ink); }

  .nav-cta {
    background: var(--plum);
    color: #FFF;
    font-size: 14px;
    font-weight: 500;
    padding: 8px 16px;
    border-radius: 8px;
    text-decoration: none;
    transition:
      background var(--dur-base) var(--ease-in-out),
      transform  var(--dur-base) var(--ease-in-out);
  }
  .nav-cta:hover { background: var(--plum-deep); }

  @media (prefers-reduced-motion: no-preference) {
    .nav-cta:hover { transform: scale(1.02); }

    .nav-logo  { animation: nav-fade-in 600ms var(--ease-out)   0ms both; }
    .nav-links { animation: nav-fade-in 600ms var(--ease-out)  80ms both; }
    .nav-cta   { animation: nav-fade-in 600ms var(--ease-out)  80ms both; }

    @keyframes nav-fade-in {
      from { opacity: 0; transform: translateY(-6px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  }

  /* Mobile: keep all three children visible (no hamburger for v1). */
  @media (max-width: 767px) {
    .nav-inner { padding: 0 16px; gap: 16px; }
    .nav-links { gap: 16px; }
    .nav-cta   { padding: 6px 14px; font-size: 13px; }
  }
</style>
