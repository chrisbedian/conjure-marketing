---
---
<section class="cta reveal">
  <div class="m-section-left">
    <div class="m-section-left__inner cta__inner">
      <p class="section-label">03 / Open</p>
      <h2 class="cta__title">Ready to direct?</h2>
      <p class="cta__sub">Open Conjure and try a real edit. No prompt box required.</p>
      <a href="https://app.onconjure.com" class="m-btn m-btn--primary m-btn--lg cta__btn">
        Open Conjure
        <svg class="cta__btn-arrow" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M 6 18 L 17 7 M 11 7 L 17 7 L 17 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .cta {
    background: var(--ink);
    padding: 120px 0;
    position: relative;
  }
  /* Hairline framing the top of the dark band — paper-tinted because
     the brand accent (ink) would vanish into the band itself. Per the
     kit's "Inverted band (ink) | Divider | rgba(255, 255, 255, 0.10)"
     surface-pairing rule. */
  .cta::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: rgba(255, 255, 255, 0.10);
  }
  @media (max-width: 767px) {
    .cta { padding: 96px 0; }
  }

  .cta__inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .cta__inner .section-label {
    margin-bottom: 24px;
  }

  .cta__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 4.5vw, 3.75rem);
    font-weight: 500;
    color: var(--paper);
    letter-spacing: -0.012em;
    line-height: 1.05;
  }
  .cta__sub {
    margin-top: 24px;
    color: rgba(255, 255, 255, 0.72);
    font-size: clamp(1.0625rem, 1.4vw, 1.25rem);
    font-weight: 400;
    line-height: 1.45;
    max-width: 540px;
  }
  .cta .m-btn {
    margin-top: 40px;
  }

  /* The primary button inverts on the dark band — cream fill + ink
     text + cream-deep on hover, per the brand kit's
     "Inverted band (ink)" surface-pairing rule. The default
     .m-btn--primary uses ink fill, which would vanish into the band. */
  .cta .m-btn--primary {
    background: var(--cream);
    color: var(--ink);
  }
  .cta .m-btn--primary:hover {
    background: var(--cream-deep);
  }

  /* Animated arrow (matches the Hero primary CTA pattern). */
  .cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .cta__btn-arrow {
    width: 20px;
    height: 20px;
    transition: transform var(--dur-base) var(--ease-out);
  }
  .cta__btn:hover .cta__btn-arrow {
    transform: translate(2px, -2px);
  }
  @media (prefers-reduced-motion: reduce) {
    .cta__btn-arrow { transition: none; }
    .cta__btn:hover .cta__btn-arrow { transform: none; }
  }
</style>
