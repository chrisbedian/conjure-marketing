---
interface Props {
  title: string;
  description: string;
  videoSlug: string;   /* e.g. "selection" — resolves to /videos/gesture-selection.{webm,mp4} */
  numeral: string;     /* "01" | "02" | "03" | "04" */
  delayMs?: number;
}
const { title, description, videoSlug, numeral, delayMs = 0 } = Astro.props;
const posterSrc = `/videos/gesture-${videoSlug}-poster.jpg`;
const webmSrc   = `/videos/gesture-${videoSlug}.webm`;
const mp4Src    = `/videos/gesture-${videoSlug}.mp4`;
---
<article class="tile reveal" style={`transition-delay: ${delayMs}ms;`}>
  <hr class="tile__rule" />
  <header class="tile__head">
    <span class="tile__numeral" aria-hidden="true">{numeral}</span>
    <h3 class="tile__title">{title}</h3>
  </header>
  <div class="tile__media" aria-label={`${title} gesture demo`}>
    <img
      src={posterSrc}
      alt=""
      class="tile__poster"
      decoding="async"
      loading="lazy"
    />
    <video
      class="tile__video"
      data-lazy
      data-crossfade
      muted
      loop
      playsinline
      preload="none"
      poster={posterSrc}
    >
      <source data-src={webmSrc} type="video/webm" />
      <source data-src={mp4Src}  type="video/mp4" />
    </video>
  </div>
  <p class="tile__desc">{description}</p>
</article>

<style>
  .tile {
    display: flex;
    flex-direction: column;
  }

  /* Anthropic-style hairline at the top of each card. */
  .tile__rule {
    border: none;
    border-top: 1px solid rgba(26, 26, 31, 0.10);
    margin: 0 0 20px;
    width: 100%;
  }

  .tile__head {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 20px;
  }
  .tile__numeral {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    color: var(--plum);
    letter-spacing: 0.04em;
  }
  .tile__title {
    font-family: var(--font-sans);
    font-size: clamp(1.25rem, 1.75vw, 1.5rem);
    font-weight: 600;
    color: var(--ink);
    letter-spacing: -0.01em;
    line-height: 1.1;
  }

  .tile__media {
    position: relative;
    aspect-ratio: 4 / 3;
    background: var(--ink);
    border: 1px solid rgba(26, 26, 31, 0.08);
    overflow: hidden;
    transition: transform var(--dur-mid) var(--ease-out);
  }
  .tile:hover .tile__media {
    transform: translateY(-3px);
  }
  @media (prefers-reduced-motion: reduce) {
    .tile:hover .tile__media { transform: none; }
  }

  .tile__poster,
  .tile__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .tile__video {
    opacity: 0;
    transition: opacity 200ms var(--ease-in-out);
  }
  .tile__video.is-playing {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .tile__video { opacity: 1; transition: none; }
  }

  .tile__desc {
    margin-top: 20px;
    color: var(--ink-soft);
    font-size: var(--text-body);
    line-height: 1.55;
    max-width: 36ch;
  }
</style>
