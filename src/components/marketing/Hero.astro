---
/**
 * Hero — editorial, anthropic-inspired, two-column upper.
 *  - Left column (1.5fr): chip → headline → subhead → CTA row
 *  - Right column (1fr):  mini gesture loop (CSS+SVG, no asset required)
 */
---
<section class="hero">
  <div class="m-section-left hero__intro">
    <p class="section-label">00 / Direct</p>

    <div class="hero__top">
      <div class="hero__top-left">
        <div class="hero__chip" aria-hidden="true">
          <span class="hero__chip-dot"></span>
          <span class="hero__chip-label">NOW IN PRIVATE BETA</span>
        </div>

        <h1 class="hero__title">
          <span class="hero__title-line">Direct the AI.</span><br />
          <span class="hero__title-line">Down to the detail.</span>
        </h1>
        <p class="hero__subtitle">
          An AI design tool for professionals. Brief it the way you'd brief a designer, with references, selections, and constraints.
        </p>
        <div class="hero__cta-row">
          <a href="/waitlist" class="m-btn m-btn--primary m-btn--md cta__btn">
            Request access
            <svg class="cta__btn-arrow" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M 5 12 L 19 12 M 13 6 L 19 12 L 13 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            </svg>
          </a>
          <a href="#thesis" class="hero__scroll-cue" aria-label="Scroll to the next section">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" aria-hidden="true">
              <path d="M 6 9 L 12 15 L 18 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>

      <div class="hero__top-right">
        <div class="hero__mini" aria-label="A miniature loop showing a reference photo dragged onto a card; the AI restyles the eyebrow, image, and button in a coordinated cascade">
          <svg viewBox="0 0 360 297" class="hero__mini-svg" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <!-- Reference + cascade gradients — kit-aligned. Sky and
                   button both use "forest moss" (one of the kit's avatar
                   gradients, 135° #3D6E51 → #5C8252). Hills pull from
                   the ink ramp so the silhouette stays inside the brand. -->
              <linearGradient id="miniRefSky" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%"   stop-color="#3D6E51"/>
                <stop offset="100%" stop-color="#5C8252"/>
              </linearGradient>
              <linearGradient id="miniRefHills" x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%"   stop-color="#2A2A30"/>
                <stop offset="100%" stop-color="#1A1A1F"/>
              </linearGradient>
              <linearGradient id="miniBtnFill" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%"   stop-color="#3D6E51"/>
                <stop offset="100%" stop-color="#5C8252"/>
              </linearGradient>

              <clipPath id="miniBtnClip">
                <rect x="32" y="227" width="116" height="34" rx="6"/>
              </clipPath>
              <clipPath id="miniImgClip">
                <rect x="32" y="52" width="296" height="102" rx="6"/>
              </clipPath>
              <clipPath id="miniRefClip">
                <rect x="-22" y="-16" width="44" height="32" rx="4"/>
              </clipPath>
            </defs>

            <!-- canvas -->
            <rect x="0" y="0" width="360" height="297" fill="#1A1A1F"/>

            <!-- traffic-light dots — Mac-style window chrome at low
                 alpha. Signals "this is a window" without committing
                 to ambiguous tab/URL-bar shapes that read mid-cascade. -->
            <circle cx="14" cy="16" r="3" fill="rgba(255,255,255,0.10)"/>
            <circle cx="26" cy="16" r="3" fill="rgba(255,255,255,0.10)"/>
            <circle cx="38" cy="16" r="3" fill="rgba(255,255,255,0.10)"/>

            <!-- the website card -->
            <g class="hero__mini-card">
              <rect x="20" y="40" width="320" height="233" rx="10" fill="#2A2A30" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>

              <!-- image area: stylized illustration cross-fades into a real
                   sunset photograph during the cascade. -->
              <g clip-path="url(#miniImgClip)">
                <!-- BEFORE: stylized illustration -->
                <g class="hero__mini-img-illust">
                  <rect x="32" y="52" width="296" height="102" rx="6" fill="rgba(255,255,255,0.05)"/>
                  <path d="M32 154 L100 116 L150 134 L210 102 L270 132 L328 120 L328 154 Z" fill="rgba(255,255,255,0.08)"/>
                  <circle cx="276" cy="86" r="6" fill="rgba(255,255,255,0.10)"/>
                </g>

                <!-- AFTER: real photograph — the cascade demonstrates
                     that the AI handles real imagery, not just stylized
                     placeholder gradients. The denim-wash swatch + button
                     palette echoes the cool blue tones of the photo. -->
                <image
                  class="hero__mini-img-photo"
                  href="https://images.unsplash.com/photo-1551801691-f0bce83d4f68?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
                  x="32" y="52" width="296" height="102"
                  preserveAspectRatio="xMidYMid slice"
                  opacity="0"
                />
              </g>

              <!-- eyebrow: bar (before) cross-fades to "TRAVEL" (after) -->
              <rect class="hero__mini-eyebrow-bar" x="32" y="166" width="48" height="6" rx="2" fill="rgba(236, 233, 224, 0.55)"/>
              <text class="hero__mini-eyebrow-text" x="32" y="172" opacity="0">TRAVEL</text>

              <!-- headline: two placeholder bars (before) cross-fade to a single line of real headline (after) -->
              <g class="hero__mini-headline-bars">
                <rect x="32" y="188" width="180" height="9" rx="2.5" fill="rgba(255,255,255,0.85)"/>
                <rect x="32" y="202" width="120" height="9" rx="2.5" fill="rgba(255,255,255,0.85)"/>
              </g>
              <text class="hero__mini-headline-text" x="32" y="202" opacity="0">Three days in the Isle of Skye</text>

              <!-- button: gray base; gradient fill + "Plan the route" label cross-fade in on the cascade beat -->
              <g clip-path="url(#miniBtnClip)">
                <rect x="32" y="227" width="116" height="34" rx="6" fill="rgba(255,255,255,0.12)"/>
                <rect class="hero__mini-fill" x="32" y="227" width="116" height="34" rx="6" fill="url(#miniBtnFill)" opacity="0"/>
              </g>
              <rect class="hero__mini-btn-label-bar" x="56" y="240" width="68" height="8" rx="2" fill="rgba(255,255,255,0.95)"/>
              <text class="hero__mini-btn-label-text" x="90" y="249" text-anchor="middle" opacity="0">Plan the route</text>

              <!-- secondary link: bar cross-fades to "Read the guide" -->
              <rect class="hero__mini-link-bar" x="164" y="241" width="56" height="6" rx="2" fill="rgba(255,255,255,0.40)"/>
              <text class="hero__mini-link-text" x="164" y="247" opacity="0">Read the guide</text>
            </g>

            <!-- selection ring around the whole card -->
            <rect class="hero__mini-selection" x="17" y="37" width="326" height="239" rx="12"
                  fill="none" stroke-width="1.5" opacity="0"/>

            <!-- reference photo chip: sky + hills + sun -->
            <g class="hero__mini-swatch">
              <g clip-path="url(#miniRefClip)">
                <rect x="-22" y="-16" width="44" height="32" fill="url(#miniRefSky)"/>
                <path d="M-22 6 L-10 -2 L-2 4 L8 -4 L18 2 L22 0 L22 16 L-22 16 Z" fill="url(#miniRefHills)"/>
                <circle cx="10" cy="-6" r="2.5" fill="#FAFAFA" opacity="0.85"/>
              </g>
              <rect x="-22" y="-16" width="44" height="32" rx="4" fill="none" stroke="rgba(255,255,255,0.30)" stroke-width="1"/>
            </g>

            <!-- cursor -->
            <g class="hero__mini-cursor">
              <path d="M0 0 L0 13 L4 10 L6 14 L7.5 13.5 L5.5 9.5 L10 9.5 Z"
                    stroke-width="0.5"/>
            </g>
          </svg>
        </div>
      </div>
    </div>
  </div>

</section>

<style>
  .hero {
    background: var(--cream);
    padding: 112px 0 80px;
    position: relative;
  }
  /* Mobile: keep the same 32px gap between nav (64px tall, fixed) and the
     section-label as desktop has — drop only the bottom padding. */
  @media (max-width: 767px) {
    .hero { padding: 112px 0 56px; }
  }

  .hero__intro .section-label {
    margin-bottom: 32px;
  }

  /* Two-column upper hero. Stacks at <900px. The mini loop bottom-
     aligns to the CTA-row bottom so the two columns share a baseline
     instead of just a top edge — center alignment leaves the loop
     reading as orphaned in the upper half of the row. */
  .hero__top {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(0, 1fr);
    gap: 64px;
    align-items: end;
    margin-bottom: 56px;
  }
  @media (max-width: 899px) {
    .hero__top {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  /* Status chip — mono "NOW IN PRIVATE BETA" with a pulsing ink dot. */
  .hero__chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px 6px 10px;
    background: var(--accent-wash);
    border: 1px solid var(--accent-wash-glow);
    border-radius: var(--radius-pill);
    margin-bottom: 24px;
  }
  .hero__chip-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    animation: chip-pulse 2400ms var(--ease-in-out) infinite;
  }
  .hero__chip-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--color-accent-hover);
  }
  @keyframes chip-pulse {
    0%, 100% { box-shadow: 0 0 0 0   rgba(26, 26, 31, 0.5); }
    60%      { box-shadow: 0 0 0 6px rgba(26, 26, 31, 0);   }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__chip-dot { animation: none; }
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 5.75rem);
    font-weight: 500;
    color: var(--ink);
    line-height: 1.0;
    letter-spacing: -0.018em;
    max-width: 16ch;
  }
  /* When the hero stacks single-column the headline gets the full layout
     column to itself, so scale it more aggressively. */
  @media (max-width: 899px) {
    .hero__title {
      font-size: clamp(3rem, 9vw, 5.75rem);
    }
  }
  /* Each clause stays as one line at any viewport that can hold it. The
     <br /> still creates the explicit break between the two lines; this
     just prevents the browser from breaking *within* a clause when the
     column is right at the boundary of the rendered text width. Allow
     normal wrapping under 600px where the column gets too narrow for
     the larger of the two clauses. */
  .hero__title-line {
    white-space: nowrap;
  }
  @media (max-width: 599px) {
    .hero__title-line { white-space: normal; }
  }

  .hero__subtitle {
    margin-top: 28px;
    color: var(--ink-soft);
    font-size: clamp(1.0625rem, 1.4vw, 1.375rem);
    font-weight: 400;
    line-height: 1.5;
    max-width: 540px;
    /* Avoid orphan-word last line ("constraints." alone). pretty
       lets the browser redistribute the rag across the paragraph
       so the last line isn't a single word. */
    text-wrap: pretty;
  }

  .hero__cta-row {
    margin-top: 40px;
    display: inline-flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  /* Soft scroll cue — chevron next to the primary CTA that gently
     bounces to invite a scroll, smooth-anchors to the next section.
     Reads as invitation, not a button: no fill, no border, low alpha
     until hover. */
  .hero__scroll-cue {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--ink-quiet);
    text-decoration: none;
    transition: color var(--dur-base) var(--ease-in-out);
  }
  .hero__scroll-cue:hover { color: var(--ink); }
  @media (prefers-reduced-motion: no-preference) {
    .hero__scroll-cue svg {
      animation: hero-scroll-cue 2400ms var(--ease-in-out) infinite;
    }
    @keyframes hero-scroll-cue {
      0%, 100% { transform: translateY(0); }
      50%      { transform: translateY(4px); }
    }
  }

  /* Animated arrow inside the primary CTA. */
  .cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .cta__btn-arrow {
    width: 20px;
    height: 20px;
    transition: transform var(--dur-base) var(--ease-out);
  }
  .cta__btn:hover .cta__btn-arrow {
    transform: translateX(2px);
  }
  @media (prefers-reduced-motion: reduce) {
    .cta__btn-arrow { transition: none; }
    .cta__btn:hover .cta__btn-arrow { transform: none; }
  }

  /* ------------------------------------------------------------------
     Mini gesture loop — CSS+SVG, 6s repeating cycle. No video asset.
     Story: cursor enters with a warm gradient swatch, drags it onto an
     empty target layer, drops it. Selection blooms, AI dot pulses, the
     target fills with the reference gradient. Hold. Reset. Loop.
     "Drop a reference, the AI matches it" — without text.
     ------------------------------------------------------------------ */
  .hero__mini {
    width: 100%;
    max-width: 420px;
    margin-left: auto;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--color-border-soft);
    /* Loop is decorative — keep the regular pointer everywhere inside,
       so hovering the SVG <text> elements doesn't show the I-beam. */
    cursor: default;
  }
  .hero__mini * {
    cursor: inherit;
  }
  /* Below 900px the layout stacks single-column; let the mini fill the
     full column flush-left, matching the text above. */
  @media (max-width: 899px) {
    .hero__mini {
      margin-left: 0;
      max-width: none;
    }
  }
  .hero__mini-svg {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Cursor: enters from upper-right, drags reference toward the button,
     holds while the cascade runs, exits. Loop runtime extended 7s -> 9s
     to give the 5-beat cascade room to breathe. */
  .hero__mini-cursor {
    animation: mini-cursor 7000ms var(--ease-in-out) infinite;
  }
  .hero__mini-cursor path {
    fill: var(--paper);
    stroke: var(--ink);
  }
  @keyframes mini-cursor {
    /* Tip is offset (-5, -7) from swatch center so the cursor body sits
       over the middle of the dragged image rather than dangling off it.
       Drag compressed to 0-22% (vs 0-34%) so it reads as a quick decisive
       motion rather than a slow trip. */
    0%   { transform: translate(317px, 33px);  opacity: 0; }
    8%   { opacity: 1; }
    5%   { transform: translate(317px, 33px); }
    22%  { transform: translate(177px, 184px); }   /* arrives at the button */
    30%  { transform: translate(177px, 184px); opacity: 1; }   /* hold past the drop */
    38%  { transform: translate(177px, 184px); opacity: 0; }   /* then fade — no return trip */
    100% { transform: translate(177px, 184px); opacity: 0; }
  }

  .hero__mini-swatch {
    animation: mini-swatch 7000ms var(--ease-in-out) infinite;
  }
  @keyframes mini-swatch {
    0%, 3%   { transform: translate(322px,  40px); opacity: 0; }
    6%       { transform: translate(322px,  40px); opacity: 1; }
    22%      { transform: translate(182px, 191px); opacity: 1; }
    26%      { transform: translate(182px, 191px); opacity: 1; }
    30%      { transform: translate(182px, 191px); opacity: 0; }   /* dropped */
    100%     { transform: translate(322px,  40px); opacity: 0; }
  }

  .hero__mini-selection {
    /* The mini-loop canvas is a self-contained inverted band (#1A1A1F).
       Per the kit's surface-pairing logic, the brand accent inverts to
       cream on dark surfaces — using --color-accent here would render
       the ring ink-on-ink and disappear. */
    stroke: var(--cream);
    animation: mini-selection 7000ms var(--ease-in-out) infinite;
  }
  @keyframes mini-selection {
    0%,  20%  { opacity: 0; }
    26%, 77%  { opacity: 1; }
    100% { opacity: 0; }
  }

  /* ------------------------------------------------------------------
     Cascade — 5 beats, each ~6% wide, staggered every 6%:
       Beat 1 (36%): image (illustration -> photo)
       Beat 2 (42%): eyebrow (bar -> "TRAVEL")
       Beat 3 (48%): headline (two bars -> "Three days in the Sierras.")
       Beat 4 (54%): button (gradient fill + "Plan the route" label)
       Beat 5 (60%): secondary link (bar -> "Read the guide")
     All "before" elements fade out, "after" elements fade in. Cascade
     finishes by 66%; the finished card holds 66-77% (~0.77s at 7s loop).
     Snap back at the end while the selection ring fades.
     ------------------------------------------------------------------ */

  /* Beat 1 — image */
  .hero__mini-img-illust {
    animation: mini-cascade-out-1 7000ms var(--ease-in-out) infinite;
  }
  .hero__mini-img-photo {
    animation: mini-cascade-in-1 7000ms var(--ease-in-out) infinite;
  }
  @keyframes mini-cascade-out-1 {
    0%,  36%  { opacity: 1; }
    42%, 77%  { opacity: 0; }
    100% { opacity: 1; }
  }
  @keyframes mini-cascade-in-1 {
    0%,  36%  { opacity: 0; }
    42%, 77%  { opacity: 1; }
    100% { opacity: 0; }
  }

  /* Beat 2 — eyebrow */
  .hero__mini-eyebrow-bar {
    animation: mini-cascade-out-2 7000ms var(--ease-in-out) infinite;
  }
  .hero__mini-eyebrow-text {
    animation: mini-cascade-in-2 7000ms var(--ease-in-out) infinite;
  }
  @keyframes mini-cascade-out-2 {
    0%,  42%  { opacity: 1; }
    48%, 77%  { opacity: 0; }
    100% { opacity: 1; }
  }
  @keyframes mini-cascade-in-2 {
    0%,  42%  { opacity: 0; }
    48%, 77%  { opacity: 1; }
    100% { opacity: 0; }
  }

  /* Beat 3 — headline */
  .hero__mini-headline-bars {
    animation: mini-cascade-out-3 7000ms var(--ease-in-out) infinite;
  }
  .hero__mini-headline-text {
    animation: mini-cascade-in-3 7000ms var(--ease-in-out) infinite;
  }
  @keyframes mini-cascade-out-3 {
    0%,  48%  { opacity: 1; }
    54%, 77%  { opacity: 0; }
    100% { opacity: 1; }
  }
  @keyframes mini-cascade-in-3 {
    0%,  48%  { opacity: 0; }
    54%, 77%  { opacity: 1; }
    100% { opacity: 0; }
  }

  /* Beat 4 — button (gradient fill + label text). Existing .hero__mini-fill
     is the gradient layer; -btn-label-bar fades out as -btn-label-text fades
     in. All three share beat-4 timing. */
  .hero__mini-fill {
    animation: mini-cascade-in-4 7000ms var(--ease-in-out) infinite;
  }
  .hero__mini-btn-label-bar {
    animation: mini-cascade-out-4 7000ms var(--ease-in-out) infinite;
  }
  .hero__mini-btn-label-text {
    animation: mini-cascade-in-4 7000ms var(--ease-in-out) infinite;
  }
  @keyframes mini-cascade-out-4 {
    0%,  54%  { opacity: 1; }
    60%, 77%  { opacity: 0; }
    100% { opacity: 1; }
  }
  @keyframes mini-cascade-in-4 {
    0%,  54%  { opacity: 0; }
    60%, 77%  { opacity: 1; }
    100% { opacity: 0; }
  }

  /* Beat 5 — secondary link */
  .hero__mini-link-bar {
    animation: mini-cascade-out-5 7000ms var(--ease-in-out) infinite;
  }
  .hero__mini-link-text {
    animation: mini-cascade-in-5 7000ms var(--ease-in-out) infinite;
  }
  @keyframes mini-cascade-out-5 {
    0%,  60%  { opacity: 1; }
    66%, 77%  { opacity: 0; }
    100% { opacity: 1; }
  }
  @keyframes mini-cascade-in-5 {
    0%,  60%  { opacity: 0; }
    66%, 77%  { opacity: 1; }
    100% { opacity: 0; }
  }

  /* SVG text styling — matches the page font conventions. */
  .hero__mini-eyebrow-text {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.08em;
    /* Forest-moss flat — the lighter stop (#5C8252) of the same kit
       avatar gradient that paints the swatch sky and button fill, so
       "TRAVEL" reads as a brand-derived accent on the dark canvas. */
    fill: #5C8252;
  }
  .hero__mini-headline-text {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: -0.01em;
    fill: rgba(255, 255, 255, 0.95);
  }
  .hero__mini-btn-label-text {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    fill: var(--color-accent-text);
  }
  .hero__mini-link-text {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 600;
    fill: rgba(255, 255, 255, 0.6);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__mini-cursor,
    .hero__mini-swatch,
    .hero__mini-selection,
    .hero__mini-fill,
    .hero__mini-img-illust,
    .hero__mini-img-photo,
    .hero__mini-eyebrow-bar,
    .hero__mini-eyebrow-text,
    .hero__mini-headline-bars,
    .hero__mini-headline-text,
    .hero__mini-btn-label-bar,
    .hero__mini-btn-label-text,
    .hero__mini-link-bar,
    .hero__mini-link-text { animation: none; }
    /* Reduced motion shows the finished "after" state. */
    .hero__mini-selection,
    .hero__mini-fill,
    .hero__mini-img-photo,
    .hero__mini-eyebrow-text,
    .hero__mini-headline-text,
    .hero__mini-btn-label-text,
    .hero__mini-link-text { opacity: 1; }
    .hero__mini-img-illust,
    .hero__mini-eyebrow-bar,
    .hero__mini-headline-bars,
    .hero__mini-btn-label-bar,
    .hero__mini-link-bar,
    .hero__mini-swatch,
    .hero__mini-cursor { opacity: 0; }
  }

  /* Page-load staggered fade-in (hero only, runs once). */
  @media (prefers-reduced-motion: no-preference) {
    .hero__intro .section-label  { animation: hero-fade-in 600ms var(--ease-out)   0ms both; }
    .hero__chip                  { animation: hero-fade-in 600ms var(--ease-out)  80ms both; }
    .hero__title                 { animation: hero-fade-in 700ms var(--ease-out) 160ms both; }
    .hero__subtitle              { animation: hero-fade-in 700ms var(--ease-out) 280ms both; }
    .hero__cta-row               { animation: hero-fade-in 700ms var(--ease-out) 400ms both; }
    .hero__top-right             { animation: hero-fade-in 800ms var(--ease-out) 240ms both; }
    @keyframes hero-fade-in {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  }
</style>
